# ══════════════════════════════════════════════════════════════════════
#  IntrusionX SE — Backend Local Development Environment
#  Loaded by python-dotenv when running:  python main.py  (local dev)
#  Docker Compose reads the ROOT-LEVEL .env instead — see /.env
#
#  ⚠  NEVER commit this file. It is listed in .gitignore.
# ══════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=IntrusionX SE
APP_VERSION=2.0.0
DEBUG=True

# ── Server ───────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── PostgreSQL (Firebase Data Connect / Cloud SQL) ────────────────────
#    Format: postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
#    Get these credentials from the Firebase Console -> Data Connect -> Settings
DATABASE_URL=postgresql://nexusscope_user:REPLACE_WITH_PASSWORD@dpg-d7ce99jbc2fs73eh9ppg-a.oregon-postgres.render.com/nexusscope

# ── Firebase Admin SDK ───────────────────────────────────────────────
#    Download your service-account JSON from Firebase Console →
#    Project Settings → Service Accounts → Generate new private key
#    Place the file at the path below (relative to backend/).
FIREBASE_CRED_PATH=./shared/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Redis (Celery broker) ────────────────────────────────────────────
REDIS_URL=rediss://red-d7cemo28qa3s73biekig:REPLACE_WITH_PASSWORD@oregon-keyvalue.render.com:6379/0
CELERY_BROKER_URL=rediss://red-d7cemo28qa3s73biekig:REPLACE_WITH_PASSWORD@oregon-keyvalue.render.com:6379/0
CELERY_RESULT_BACKEND=rediss://red-d7cemo28qa3s73biekig:REPLACE_WITH_PASSWORD@oregon-keyvalue.render.com:6379/1

# ── Telegram Bot ─────────────────────────────────────────────────────
#    Create via @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# ── WhatsApp Cloud API (Meta for Developers) ─────────────────────────
#    https://developers.facebook.com/apps → WhatsApp → API Setup
#    Set the same WHATSAPP_VERIFY_TOKEN in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_A_RANDOM_SECRET_STRING
WHATSAPP_ACCESS_TOKEN=REPLACE_WITH_PERMANENT_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_PHONE_NUMBER_ID

# ── HTTP Client Tuning ───────────────────────────────────────────────
HTTP_TIMEOUT=12.0
USER_AGENT=IntrusionX-SE/2.0 (OSINT Aggregation Engine)

# ── Playwright ───────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=True

# ── CORS (comma-separated allowed origins) ───────────────────────────
#    Keep * for dev. Restrict in production.
CORS_ORIGINS=*
