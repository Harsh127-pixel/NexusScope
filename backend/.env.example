# ── HTTP Client Tuning ───────────────────────────────────────────────
HTTP_TIMEOUT=12.0
USER_AGENT=IntrusionX-SE/2.0 (OSINT Aggregation Engine)
DEFAULT_SCRAPER_PROXY=

# ── Playwright ───────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_BROWSER=chromium

# ── CORS (comma-separated allowed origins) ───────────────────────────
#    Keep * for dev. Restrict in production.
CORS_ORIGINS=*

# ════════════════════════════════════════════════════════════════════════
#  INTELLIGENCE THEATER CONFIGURATION
# ════════════════════════════════════════════════════════════════════════

# ── Theater 1: Dark Web / Onion ──────────────────────────────────────
#    Requires Tor service running locally. Install Tor Browser or Tor daemon.
#    On Linux:   sudo apt install tor && sudo service tor start
#    On macOS:   brew install tor && brew services start tor
#    On Windows: Download Tor Expert Bundle from torproject.org
#    External relay: Point to a remote SOCKS5 Tor relay instead of localhost
#    e.g. TOR_PROXY_URL=socks5://16.16.25.208:9050
TOR_PROXY_URL=socks5://127.0.0.1:9050
TOR_TIMEOUT=30

# ── Theater 3: Identity & Credential Hunting ─────────────────────────
#    HaveIBeenPwned API key — $3.50/month at haveibeenpwned.com/API/Key
#    Leave blank to skip breach lookups (Gravatar will still work).
HIBP_API_KEY=

# ── Theater 2: General Recon (Phone Lookup) ──────────────────────────
#    NumVerify API key for carrier + line-type lookups (free tier: 100 req/mo)
#    Get at: apilayer.com/marketplace/numverify-api
#    Leave blank to use free unauthenticated fallback (limited accuracy).
NUMVERIFY_API_KEY=

