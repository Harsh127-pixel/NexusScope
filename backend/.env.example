# ══════════════════════════════════════════════════════════════
#  IntrusionX SE — Environment Variables Template
#  Copy to .env and fill in real values. NEVER commit .env.
# ══════════════════════════════════════════════════════════════

# PostgreSQL
DATABASE_URL=postgresql://osint_user:osint_pass@localhost:5432/intrusion_x_db

# Firebase Admin SDK — path to service-account JSON
FIREBASE_CRED_PATH=/etc/secrets/firebase-service-account.json

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp Cloud API (Meta for Developers)
WHATSAPP_VERIFY_TOKEN=your_random_strong_verify_token_here
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Tuning
HTTP_TIMEOUT=12.0
