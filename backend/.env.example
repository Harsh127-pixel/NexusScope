# ══════════════════════════════════════════════════════════════════════
#  IntrusionX SE — Backend Local Development Environment
#  Loaded by python-dotenv when running:  python main.py  (local dev)
#  Docker Compose reads the ROOT-LEVEL .env instead — see /.env
#
#  ⚠  NEVER commit this file. It is listed in .gitignore.
# ══════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=IntrusionX SE
APP_VERSION=2.0.0
DEBUG=True

# ── Server ───────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── PostgreSQL (Firebase Data Connect / Cloud SQL) ────────────────────
#    Format: postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
#    Get these credentials from the Firebase Console -> Data Connect -> Settings
DATABASE_URL=postgresql://nexusscope_user:Q1B2KdDFxKoETjrJBc7tx7Lf9zUWlU4Q@dpg-d7ce99jbc2fs73eh9ppg-a.oregon-postgres.render.com/nexusscope

# ── Firebase Admin SDK ───────────────────────────────────────────────
#    Download your service-account JSON from Firebase Console →
#    Project Settings → Service Accounts → Generate new private key
#    Place the file at the path below (relative to backend/).
FIREBASE_CRED_PATH=./shared/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Redis (Celery broker) ────────────────────────────────────────────
REDIS_URL=rediss://red-d7cemo28qa3s73biekig:76S9UQvXfX4v6hTA2tNzaqzrBUyTGh6h@oregon-keyvalue.render.com:6379/0?ssl_cert_reqs=CERT_NONE
CELERY_BROKER_URL=rediss://red-d7cemo28qa3s73biekig:76S9UQvXfX4v6hTA2tNzaqzrBUyTGh6h@oregon-keyvalue.render.com:6379/0?ssl_cert_reqs=CERT_NONE
CELERY_RESULT_BACKEND=rediss://red-d7cemo28qa3s73biekig:76S9UQvXfX4v6hTA2tNzaqzrBUyTGh6h@oregon-keyvalue.render.com:6379/1?ssl_cert_reqs=CERT_NONE

